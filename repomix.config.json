{
  "output": {
    "filePath": "graphify-out/repomix-output.xml",
    "style": "xml",
    "removeComments": true,
    "removeEmptyLines": true
  },
  "include": ["src/**/*"],
  "ignore": {
    "customPatterns": [
      "**/node_modules/**",
      "**/dist/**",
      "**/.graphify_*",
      "**/cache/**",
      "**/*.svg"
    ]
  }
}