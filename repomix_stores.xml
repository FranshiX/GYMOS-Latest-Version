<file path="src/store/useWorkoutLogStore.ts">
import { create } from 'zustand'
import { WorkoutLog, ExerciseLog, SetLog } from '../domain/workoutLog/types'
import logsData from '../data/workoutLogs.json'
interface WorkoutLogStore {
  logs: WorkoutLog[]
  getLogsForMember: (memberId: string) => WorkoutLog[]
  getLogsForPlan: (memberId: string, planId: string) => WorkoutLog[]
  getLogById: (logId: string) => WorkoutLog | undefined
  getTodayLog: (memberId: string, dayId: string) => WorkoutLog | undefined
  getStreakForMember: (memberId: string) => number
  startLog: (memberId: string, planId: string, dayId: string) => WorkoutLog
  updateSetLog: (
    logId: string,
    exerciseId: string,
    setNumber: number,
    update: Partial<SetLog>
  ) => void
  addExerciseLog: (logId: string, exerciseLog: Omit<ExerciseLog, 'id'>) => void
  finishLog: (logId: string) => void
  deleteLog: (logId: string) => void
  getMaxWeightForExercise: (memberId: string, exerciseId: string) => number
  getWeightProgressForExercise: (
    memberId: string,
    exerciseId: string
  ) => { date: string; maxWeight: number }[]
}
export const useWorkoutLogStore = create<WorkoutLogStore>((set, get) => ({
  logs: logsData as WorkoutLog[],
  getLogsForMember: (memberId) =>
    get()
      .logs.filter((l) => l.memberId === memberId)
      .sort((a, b) => b.date.localeCompare(a.date)),
  getLogsForPlan: (memberId, planId) =>
    get().logs.filter((l) => l.memberId === memberId && l.workoutPlanId === planId),
  getLogById: (logId) => get().logs.find((l) => l.id === logId),
  getTodayLog: (memberId, dayId) => {
    const today = new Date().toISOString().split('T')[0]
    return get().logs.find(
      (l) => l.memberId === memberId && l.workoutDayId === dayId && l.date === today
    )
  },
  getStreakForMember: (memberId) => {
    const logs = get()
      .logs.filter((l) => l.memberId === memberId)
      .map((l) => l.date)
      .sort()
      .reverse()
    if (logs.length === 0) return 0
    const uniqueDates = [...new Set(logs)]
    let streak = 0
    const today = new Date()
    for (let i = 0; i < uniqueDates.length; i++) {
      const expected = new Date(today)
      expected.setDate(today.getDate() - i)
      const expectedStr = expected.toISOString().split('T')[0]
      if (uniqueDates[i] === expectedStr) {
        streak++
      } else {
        break
      }
    }
    return streak
  },
  startLog: (memberId, planId, dayId) => {
    const newLog: WorkoutLog = {
      id: `log_${Date.now()}`,
      memberId,
      workoutPlanId: planId,
      workoutDayId: dayId,
      date: new Date().toISOString().split('T')[0],
      exercises: [],
    }
    set((s) => ({ logs: [...s.logs, newLog] }))
    return newLog
  },
  updateSetLog: (logId, exerciseId, setNumber, update) => {
    set((s) => ({
      logs: s.logs.map((log) => {
        if (log.id !== logId) return log
        return {
          ...log,
          exercises: log.exercises.map((ex) => {
            if (ex.exerciseId !== exerciseId) return ex
            return {
              ...ex,
              sets: ex.sets.map((st) =>
                st.setNumber === setNumber ? { ...st, ...update } : st
              ),
            }
          }),
        }
      }),
    }))
  },
  addExerciseLog: (logId, exerciseLog) => {
    const newExLog: ExerciseLog = { ...exerciseLog, id: `elog_${Date.now()}` }
    set((s) => ({
      logs: s.logs.map((log) =>
        log.id === logId
          ? { ...log, exercises: [...log.exercises, newExLog] }
          : log
      ),
    }))
  },
  finishLog: (logId) => {
    console.log('Log finished:', logId)
  },
  deleteLog: (logId) => {
    set((s) => ({ logs: s.logs.filter((l) => l.id !== logId) }))
  },
  getMaxWeightForExercise: (memberId, exerciseId) => {
    const logs = get().logs.filter((l) => l.memberId === memberId)
    let max = 0
    for (const log of logs) {
      const ex = log.exercises.find((e) => e.exerciseId === exerciseId)
      if (ex) {
        for (const set of ex.sets) {
          if (set.completed && set.weight > max) max = set.weight
        }
      }
    }
    return max
  },
  getWeightProgressForExercise: (memberId, exerciseId) => {
    const logs = get()
      .logs.filter((l) => l.memberId === memberId)
      .sort((a, b) => a.date.localeCompare(b.date))
    return logs
      .map((log) => {
        const ex = log.exercises.find((e) => e.exerciseId === exerciseId)
        if (!ex) return null
        const maxWeight = Math.max(...ex.sets.filter((s) => s.completed).map((s) => s.weight), 0)
        return { date: log.date, maxWeight }
      })
      .filter(Boolean) as { date: string; maxWeight: number }[]
  },
}))
</file>

