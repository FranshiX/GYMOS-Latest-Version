  getMembershipById: (id) => {
    return get().memberships.find(m => m.id === id)
  },
  getActiveMembership: (memberId, activeMembershipId) => {
    if (!activeMembershipId) return undefined
    return get().memberships.find(
      m => m.id === activeMembershipId && m.memberId === memberId
    )
  },
  consumeStamp: (membershipId) => {
    set(state => ({
      memberships: state.memberships.map(m =>
        m.id === membershipId
          ? { ...m, stampsUsed: m.stampsUsed + 1 }
          : m
      ),
    }))
  },
  addMembership: (membership) => {
    set(state => ({ memberships: [...state.memberships, membership] }))
  },
}))
