import { useMemo, useCallback } from 'react';
import { useTranslation } from 'react-i18next';
import { useNavigate, useParams } from 'react-router-dom';
import { useWorkoutPlanStore } from '../../store/useWorkoutPlanStore';
import { useWorkoutLogStore } from '../../store/useWorkoutLogStore';
import { useMemberStore } from '../../store/useMemberStore';
import { StreakWidget } from '../../components/shared/StreakWidget';
export function MyWorkoutScreen() {
  const { phone } = useParams<{ phone: string }>();
  const { t, i18n } = useTranslation();
  const isAr = i18n.language === 'ar';
  const dir = i18n.dir();
  const navigate = useNavigate();
  const { members } = useMemberStore();
  const { plans } = useWorkoutPlanStore();
  const { getLogsForMember, getStreakForMember } = useWorkoutLogStore();
  const member = useMemo(
    () => members.find((m) => m.phone === phone),
    [members, phone]
  );
  const logs = useMemo(
    () => getLogsForMember(member?.id ?? ''),
    [getLogsForMember, member?.id]
  );
  const streak = useMemo(
    () => getStreakForMember(member?.id ?? ''),
    [getStreakForMember, member?.id]
  );
  const customPlan = useMemo(
    () => plans.find((p) => p.type === 'CUSTOM' && p.assignedMemberId === member?.id),
    [plans, member?.id]
  );
  const generalPlans = useMemo(
    () => plans.filter((p) => p.type === 'GENERAL'),
    [plans]
  );
  const activePlan = customPlan ?? generalPlans[0];
  const handleDayClick = useCallback(
    (dayId: string, planId: string) => {
      navigate(`/member/${phone}/workout/${dayId}?planId=${planId}`);
    },
    [navigate, phone]
  );
  if (!member) {
    return (
      <div
        data-screen="my-workout"
        dir={dir}
        className="flex items-center justify-center h-full"
        style={{ background: 'var(--color-bg-primary)' }}
      >
        <p style={{ color: 'var(--color-text-muted)' }}>
          {isAr ? 'العضو غير موجود' : 'Member not found'}
        </p>
      </div>
    );
  }
  return (
    <div
      data-screen="my-workout"
      dir={dir}
      className="flex flex-col h-full"
      style={{ background: 'var(--color-bg-primary)' }}
    >
      {}
      <div
        className="px-4 pt-5 pb-3 border-b"
        style={{ borderColor: 'var(--color-bg-border)' }}
      >
        <p
          className="text-xs uppercase tracking-wider mb-0.5"
          style={{ color: 'var(--color-text-muted)' }}
        >
          {isAr ? 'مرحباً،' : 'Welcome back,'}
        </p>
        <h1 className="text-xl font-bold" style={{ color: 'var(--color-text-primary)' }}>
          {member.fullName}
        </h1>
      </div>
      <div className="flex-1 overflow-y-auto px-4 pt-4 pb-24 flex flex-col gap-5">
        {}
        <StreakWidget
          streak={streak}
          totalSessions={logs.length}
          lastWorkoutDate={logs[0]?.date}
        />
        {}
        {activePlan ? (
          <div>
            <div className="flex items-center justify-between mb-2">
              <p
                className="text-xs font-medium uppercase tracking-wider"
                style={{ color: 'var(--color-text-muted)' }}
              >
                {t('workout.my_plan')}
              </p>
              {customPlan && (
                <span
                  className="text-xs px-2 py-0.5 rounded-full"
                  style={{
                    background: 'var(--color-brand-muted)',
                    color: 'var(--color-brand)',
                  }}
                >
                  {isAr ? 'مخصص لك' : 'Custom'}
                </span>
              )}
            </div>
            {}
            <div
              className="rounded-xl px-4 py-3 mb-3"
              style={{
                background: 'var(--color-brand-muted)',
                border: '1px solid rgba(201,168,76,0.2)',
              }}
            >
              <p className="font-semibold" style={{ color: 'var(--color-text-primary)' }}>
                {isAr ? activePlan.name_ar : activePlan.name_en}
              </p>
              <p className="text-xs mt-0.5" style={{ color: 'var(--color-text-muted)' }}>
                {activePlan.days.length}{' '}
                {isAr ? 'أيام تدريب' : 'training days'}
              </p>
            </div>
            {}
            <div className="flex flex-col gap-2">
              {activePlan.days.map((day) => {
                const todayLog = logs.find((l) => l.workoutDayId === day.id);
                const isToday = todayLog?.date === new Date().toISOString().split('T')[0];
                const dayName = isAr ? day.name_ar : day.name_en;
                return (
                  <button
                    key={day.id}
                    onClick={() => handleDayClick(day.id, activePlan.id)}
                    className="w-full rounded-xl border transition-all duration-200 p-4 text-start active:scale-95"
                    style={{
                      background: 'var(--color-bg-elevated)',
                      borderColor: isToday ? 'var(--color-brand)' : 'var(--color-bg-border)',
                    }}
                  >
                    <div className="flex items-center gap-3">
                      <div
                        className="w-9 h-9 rounded-full flex items-center justify-center shrink-0 text-sm font-bold"
                        style={{
                          background: isToday ? 'var(--color-brand)' : 'var(--color-bg-border)',
                          color: isToday ? '#0A0A0A' : 'var(--color-text-muted)',
                        }}
                      >
                        {day.dayNumber}
                      </div>
                      <div className="flex-1 min-w-0">
                        <p
                          className="text-sm font-semibold truncate"
                          style={{ color: 'var(--color-text-primary)' }}
                        >
                          {dayName}
                        </p>
                        <p className="text-xs mt-0.5" style={{ color: 'var(--color-text-muted)' }}>
                          {t('workout.day_exercises', { count: day.exercises.length })}
                          {isToday && (
                            <span className="ms-2" style={{ color: 'var(--color-brand)' }}>
                              {isAr ? '• اليوم' : '• Today'}
                            </span>
                          )}
                        </p>
                      </div>
                      <svg
                        width="16"
                        height="16"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        strokeWidth="2"
                        style={{ color: 'var(--color-text-muted)' }}
                        className={isAr ? 'rotate-180' : ''}
                      >
                        <polyline points="9 18 15 12 9 6" />
                      </svg>
                    </div>
                  </button>
                );
              })}
            </div>
          </div>
        ) : (
          /* Empty state */
          <div
            className="flex flex-col items-center justify-center h-40 gap-3 rounded-xl border border-dashed"
            style={{ borderColor: 'var(--color-bg-border)' }}
          >
            <span className="text-3xl">🏋️</span>
            <p className="text-sm" style={{ color: 'var(--color-text-muted)' }}>
              {t('workout.no_plan')}
            </p>
          </div>
        )}
        {}
        {!customPlan && generalPlans.length > 1 && (
          <div>
            <p
              className="text-xs font-medium uppercase tracking-wider mb-2"
              style={{ color: 'var(--color-text-muted)' }}
            >
              {isAr ? 'برامج أخرى' : 'Other Plans'}
            </p>
            <div className="flex flex-col gap-2">
              {generalPlans.slice(1).map((plan) => (
                <div
                  key={plan.id}
                  className="rounded-xl px-4 py-3 flex items-center justify-between"
                  style={{
                    background: 'var(--color-bg-elevated)',
                    border: '1px solid var(--color-bg-border)',
                  }}
                >
                  <p className="text-sm" style={{ color: 'var(--color-text-secondary)' }}>
                    {isAr ? plan.name_ar : plan.name_en}
                  </p>
                  <span className="text-xs" style={{ color: 'var(--color-brand)' }}>
                    {plan.days.length} {isAr ? 'أيام' : 'days'}
                  </span>
                </div>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>
  );
}
</file>

<file path="src/screens/member/WorkoutDayScreen.tsx">
import { useMemo, useCallback } from 'react';
import { useParams, useNavigate } from 'react-router-dom';
import { useTranslation } from 'react-i18next';
import { useWorkoutPlanStore } from '../../store/useWorkoutPlanStore';
import { useWorkoutLogStore } from '../../store/useWorkoutLogStore';
import { useExerciseStore } from '../../store/useExerciseStore';
const WorkoutDayScreen = () => {
  const { phone, dayId } = useParams<{ phone: string; dayId: string }>();
  const navigate = useNavigate();
  const { t, i18n } = useTranslation();
  const dir = i18n.dir();
  const isAr = i18n.language === 'ar';
  const { plans } = useWorkoutPlanStore();
  const { getLogsForMember } = useWorkoutLogStore();
  const { exercises } = useExerciseStore();
  const day = useMemo(() => {
    for (const plan of plans) {
      const found = plan.days.find((d) => d.id === dayId);
      if (found) return found;
    }
    return null;
  }, [plans, dayId]);
  const todayLogs = useMemo(() => {
    if (!phone) return [];
    const today = new Date().toISOString().slice(0, 10);
    return getLogsForMember(phone).filter((log) => log.date.slice(0, 10) === today);
  }, [phone, getLogsForMember]);
  const loggedExerciseIds = useMemo(
    () => new Set(todayLogs.flatMap((log) => log.exercises.map((ex) => ex.exerciseId))),
    [todayLogs]
  );
  const handleExerciseTap = useCallback(
    (exerciseId: string) => {
      navigate(`/member/${phone}/exercise/${exerciseId}`);
    },
    [navigate, phone]
  );
  const handleStartWorkout = useCallback(() => {
    if (!day || day.exercises.length === 0) return;
    navigate(`/member/${phone}/exercise/${day.exercises[0].exerciseId}`);
  }, [navigate, phone, day]);
  const getExerciseName = useCallback((exerciseId: string) => {
    const ex = exercises.find((e) => e.id === exerciseId);
    if (!ex) return exerciseId;
    return isAr ? ex.name_ar : ex.name_en;
  }, [exercises, isAr]);
  if (!day) {
    return (
      <div
        data-screen="workout-day"
        dir={dir}
        className="min-h-screen p-4 flex items-center justify-center"
        style={{ background: 'var(--color-bg-primary)', color: 'var(--color-text-primary)' }}
      >
        <p style={{ color: 'var(--color-text-muted)' }}>{t('workout.no_plan')}</p>
      </div>
    );
  }
  const hasAnyLogged = day.exercises.some((ex) => loggedExerciseIds.has(ex.exerciseId));
  const dayName = isAr ? day.name_ar : day.name_en;
  return (
    <div
      data-screen="workout-day"
      dir={dir}
      className="min-h-screen flex flex-col"
      style={{ background: 'var(--color-bg-primary)', color: 'var(--color-text-primary)' }}
    >
      {}
      <div
        className="flex items-center gap-3 p-4 border-b"
        style={{ borderColor: 'var(--color-bg-border)' }}
      >
        <button
          onClick={() => navigate(-1)}
          className="w-8 h-8 flex items-center justify-center rounded-full"
          style={{
            background: 'var(--color-bg-elevated)',
            color: 'var(--color-text-primary)',
          }}
          aria-label="Back"
        >
          ‹
        </button>
        <h1 className="font-bold text-lg">{dayName}</h1>
      </div>
      {}
      <div className="flex-1 overflow-y-auto p-4 flex flex-col gap-3">
        {day.exercises.length === 0 ? (
          <p className="text-center text-sm mt-16" style={{ color: 'var(--color-text-muted)' }}>
            {t('workout.no_plan')}
          </p>
        ) : (
          day.exercises.map((we) => {
            const logged = loggedExerciseIds.has(we.exerciseId);
            const exerciseName = getExerciseName(we.exerciseId);
            return (
              <button
                key={we.exerciseId}
                onClick={() => handleExerciseTap(we.exerciseId)}
                className="w-full text-start rounded-2xl p-4 border transition-all duration-200 flex items-center justify-between"
                style={{
                  background: 'var(--color-bg-elevated)',
                  borderColor: logged ? 'var(--color-success)' : 'var(--color-bg-border)',
                }}
              >
                <div>
                  <p className="font-medium text-sm" style={{ color: 'var(--color-text-primary)' }}>
                    {exerciseName}
                  </p>
                  <p className="text-xs mt-0.5" style={{ color: 'var(--color-text-muted)' }}>
                    {we.sets} × {we.reps}
                    {we.restSeconds ? ` · ${we.restSeconds}s rest` : ''}
                  </p>
                </div>
                {logged && (
                  <span
                    className="text-xs font-medium shrink-0 ms-2"
                    style={{ color: 'var(--color-success)' }}
                  >
                    {t('workout.logged_today')}
                  </span>
                )}
              </button>
            );
          })
        )}
      </div>
      {}
      {day.exercises.length > 0 && (
        <div className="p-4 border-t" style={{ borderColor: 'var(--color-bg-border)' }}>
          <button
            onClick={handleStartWorkout}
            className="w-full font-bold py-3 rounded-2xl text-sm transition-all duration-200 hover:brightness-110 active:scale-95"
            style={{ background: 'var(--color-brand)', color: '#0A0A0A' }}
          >
            {hasAnyLogged ? t('workout.continue_workout') : t('workout.start_workout')}
          </button>
        </div>
      )}
    </div>
  );
};
export default WorkoutDayScreen;
</file>

